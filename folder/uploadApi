package com.sbi.yono.document.savingsaccount.edms.utility;

import java.io.File;
import java.io.FileOutputStream;
import java.io.IOException;
import java.io.OutputStream;

import org.apache.commons.codec.binary.Base64;
import org.apache.commons.lang3.exception.ExceptionUtils;
import org.apache.tika.Tika;
import org.springframework.stereotype.Component;

import com.sbi.yono.document.savingsaccount.edms.uploaddoc.GlobalException;
import com.tcs.techbone.exception.ServiceBusinessException;
import com.tcs.techbone.logger.FLogger;

@Component
public class Document {

	String thisClass = UtilityConstant.DOCUMENT;
	/**
	 * method : savedocument
	 * @Description : save document of a specific type for a given lead.
	 * @param document The document content to be saved.
	 * @param docType  The type of the document.
	 * @param leadId   The ID of the lead associated with the document
	 * @param targetSize   Compress Size for file which to write on server
	 * @return A message indicating the result of the document saving process ("Success" or "Failed to upload").
	 * @throws ServiceBusinessException If the document type is not supported or if an error occurs during the save operation.
	 */
	
	public String saveDocument(String document, String docType, String leadId, int targetSize)
	        throws ServiceBusinessException {
		String thisMethod = UtilityConstant.DOCUMENT_THIS_METHOD;
	    FLogger.info(UtilityConstant.TIER_NAME, this.getClass().getName(), thisMethod, UtilityConstant.METHOD_STARTED);
		String folderPath = UtilityConstant.OPT + File.separator + UtilityConstant.DOCUMENT + File.separator + leadId;

		String folderPathOrignal = folderPath + File.separator + UtilityConstant.ORI_FOLDER_NAME;

	    Tika tika = new Tika();
	    String detect = tika.detect(Base64.decodeBase64(document.getBytes()));

	    if (detect.contains(UtilityConstant.PDF) || detect.contains(UtilityConstant.IMAGE_JPG)
	            || detect.contains(UtilityConstant.IMAGE_PNG) || detect.contains(UtilityConstant.IMAGE_JPEG)) {
			FLogger.info(UtilityConstant.TIER_NAME, this.getClass().getName(), thisMethod, UtilityConstant.EXTESNION_CHECK);

	        File folderOrignal = new File(folderPathOrignal);
	        if (!folderOrignal.exists()) {
				FLogger.info(UtilityConstant.TIER_NAME, thisMethod, thisClass, UtilityConstant.FOLDER_NOT_EXIST);
	            boolean mkdirs = folderOrignal.mkdirs();
	            if (!mkdirs) {
					FLogger.info(UtilityConstant.TIER_NAME, thisMethod, thisClass, UtilityConstant.FOLDER_CREATION_FAIL);
	        		FLogger.info(UtilityConstant.TIER_NAME, this.getClass().getName(), thisMethod, UtilityConstant.METHOD_END);
	                return UtilityConstant.UPLOAD_FAILED;
	            }
	        }
	        File folder = new File(folderPath);
	        if (!folder.exists()) {
				FLogger.info(UtilityConstant.TIER_NAME, thisMethod, thisClass, UtilityConstant.FOLDER_NOT_EXIST);
	            boolean mkdirs = folder.mkdirs();
	            if (!mkdirs) {
					FLogger.info(UtilityConstant.TIER_NAME, thisMethod, thisClass, UtilityConstant.FOLDER_CREATION_FAIL);
	        		FLogger.info(UtilityConstant.TIER_NAME, this.getClass().getName(), thisMethod, UtilityConstant.METHOD_END);
					return UtilityConstant.UPLOAD_FAILED;
	            }
	        }

	        try (OutputStream streamOrignal = new FileOutputStream(folderPathOrignal + File.separator + docType)) {
				FLogger.info(UtilityConstant.TIER_NAME, this.getClass().getName(), thisMethod, UtilityConstant.OUTPUT_STREAM);
	            byte[] data = Base64.decodeBase64(document);
	            streamOrignal.write(data);
	        } catch (IOException e) {
				FLogger.info(UtilityConstant.TIER_NAME, thisMethod, thisClass, UtilityConstant.FAILURE_IN_SAVING);
	            ServiceBusinessException businessException = new ServiceBusinessException();
				businessException.addBizError(GlobalException.READ_WRITE_ERROR);
				FLogger.error(UtilityConstant.TIER_NAME, Document.class.getSimpleName(), thisMethod,UtilityConstant.EXCEPTION_OCCURRED + ExceptionUtils.getStackTrace(e));
	    		FLogger.info(UtilityConstant.TIER_NAME, this.getClass().getName(), thisMethod, UtilityConstant.METHOD_END);
	            throw businessException;
	        }

	        CallCompression callCompression = new CallCompression();
	        String compressedDoc = callCompression.getCompression(document, docType, targetSize);

	        try (OutputStream stream = new FileOutputStream(folderPath + File.separator + docType)) {
				FLogger.info(UtilityConstant.TIER_NAME, this.getClass().getName(), thisMethod, UtilityConstant.COMPRESS_FILE_STREAM);
	            byte[] data = Base64.decodeBase64(compressedDoc);
	            stream.write(data);
	            FLogger.info(UtilityConstant.TIER_NAME, this.getClass().getName(), thisMethod, UtilityConstant.METHOD_END);
	            return UtilityConstant.SUCCESS;
	        } catch (IOException e) {
				FLogger.info(UtilityConstant.TIER_NAME, thisMethod, thisClass, UtilityConstant.FAILURE_IN_SAVING);
	            ServiceBusinessException businessException = new ServiceBusinessException();
				businessException.addBizError(GlobalException.READ_WRITE_ERROR);
				FLogger.error(UtilityConstant.TIER_NAME, Document.class.getSimpleName(), thisMethod,UtilityConstant.EXCEPTION_OCCURRED + ExceptionUtils.getStackTrace(e));
	    		FLogger.info(UtilityConstant.TIER_NAME, this.getClass().getName(), thisMethod, UtilityConstant.METHOD_END);
	            throw businessException;
	        }

	    } else {
			FLogger.info(UtilityConstant.TIER_NAME, thisMethod, thisClass, UtilityConstant.NOT_MATCHING_EXTENSION);
	        ServiceBusinessException businessException = new ServiceBusinessException();
	        businessException.addBizError(GlobalException.FILE_NOT_SUPPORTED);
			FLogger.info(UtilityConstant.TIER_NAME, this.getClass().getName(), thisMethod, UtilityConstant.METHOD_END);
	        throw businessException;
	    }
	}

}


import java.io.IOException;
import java.nio.file.*;
import java.nio.file.attribute.PosixFilePermission;
import java.nio.file.attribute.PosixFilePermissions;
import java.util.Set;

public class PermissionUtil {

    public static void set777Recursively(Path path) {
        try {
            Set<PosixFilePermission> perms =
                    PosixFilePermissions.fromString("rwxrwxrwx");

            // Loop from root → to final path
            Path current = path.getRoot();

            for (Path part : path) {
                current = (current == null) ? part : current.resolve(part);

                if (Files.exists(current)) {
                    Files.setPosixFilePermissions(current, perms);
                }
            }

        } catch (UnsupportedOperationException e) {
            System.out.println("POSIX not supported (Windows)");
        } catch (IOException e) {
            e.printStackTrace();
        }
    }
}

