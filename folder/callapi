	/**
	 * Method Name : callEDMSAPI Description: This method generate callEDMSAPI
	 * String Method to create final request and send temporary request to EDMS
	 * using RestTemplate.postForEntity().
	 * 
	 * @param request
	 * @param edmsURL
	 * @param edmsServerPublicKey
	 * @param privateKey
	 * @param channelId
	 * @return EDMSResponse
	 */
	public EDMSResponse callEDMSAPI(Object request, String edmsURL, PublicKey edmsServerPublicKey,
			PrivateKey privateKey, String channelId) {
		String thisMethod = EdmsUploadConstants.CALL_EDMSAPI;
		FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_STARTED);
		EDMSEncryption edmsEncryption = new EDMSEncryption();
		Gson gson = new GsonBuilder().create();
		RestTemplate restTemplate = new RestTemplate();
		String uniqueVKYCServerID = null;
		uniqueVKYCServerID = edmsEncryption.generateUniqueServerId();
		String uniqueSourceServerID = uniqueServerIdGeneration(channelId, uniqueVKYCServerID);
		SecretKey aesKey = edmsEncryption.generateAESkey();
		String encryptedUniqueSourceServerID = null;
		if (null == edmsServerPublicKey) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.EDMS_SERVER_PUBLIC_KEY_NOT_PRESENT);
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return null;
		}
		try {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.ENCRYPTED_UNIQUE_SOURCE_SERVER_ID_PRESENT);
			encryptedUniqueSourceServerID = edmsEncryption.encryptRawJSON(aesKey, edmsServerPublicKey,
					uniqueSourceServerID);
		} catch (IllegalBlockSizeException | IOException e2) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.ENCRYPTED_UNIQUE_SOURCE_SERVER_ID_NOT_PRESENT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.EXCEPTION_ENCRYPTED_UNIQUE_SOURCE_SERVER_ID_NOT_PRESENT
							+ ExceptionUtils.getStackTrace(e2));
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return null;
		}

		FLogger.info(uniqueSourceServerID, encryptedUniqueSourceServerID);
		HttpHeaders tempHeaders = new HttpHeaders();
		tempHeaders.setContentType(MediaType.APPLICATION_JSON);
		tempHeaders.add(Constants.SIGNED_SENDER_TOKEN, EdmsUploadConstants.EMPTY);
		HttpEntity<String> requestToSend = new HttpEntity<>(encryptedUniqueSourceServerID, tempHeaders);
		try {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, EdmsUploadConstants.SSL_UTILITY);
			SSLUtil.turnOffSSLChecking();
		} catch (KeyManagementException | NoSuchAlgorithmException e1) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.SSL_UTILITY_NOT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.SSL_UTILITY_NOT + ExceptionUtils.getStackTrace(e1));
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return null;
		}
		ResponseEntity<String> responseString = null;
		try {
			responseString = restTemplate.postForEntity(edmsURL, requestToSend, String.class);
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, String.valueOf(responseString));
		} catch (RestClientException e) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.ERROR_IN_RESPONSE_STRING);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.ERROR_IN_RESPONSE_STRING + ExceptionUtils.getStackTrace(e));
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return null;
		}

		if (responseString.getStatusCode() != HttpStatusCode.valueOf(200)) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.UNABLE_TO_CONNECT_THE_SERVER);
		}
		String edmsResponse = responseString.getBody();
		String[] tempResponse = new String[2];

		if (null != edmsResponse && !edmsResponse.isEmpty()) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.EDMS_RESPONSE_PRESENT);
			tempResponse = edmsResponse.split(EdmsUploadConstants.COMMA);
		}
		if (tempResponse.length < EdmsUploadConstants.TWO) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.TEMP_RESPONSE_LENGHT_IS_LESS_THAN_TWO);
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return null;
		}
		String encReceiverAccessToken = tempResponse[EdmsUploadConstants.INT_ZERO];
		String signedReceiverTokenHash = tempResponse[EdmsUploadConstants.INT_ONE];

		if (null == encReceiverAccessToken || null == signedReceiverTokenHash) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.ENC_RECEIVER_ACCESS_TOKEN_OR_SIGNED_RECEIVER_TOKEN_HASH_IS_NULL);
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return null;
		}
		if (null == privateKey) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.PRIVATE_KEY_NOT_PRESENT);
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return null;
		}
		String receiverAccessToken = null;
		try {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.RECEIVER_ACCESS_TOKEN_PRESENT);
			receiverAccessToken = edmsEncryption.decReceiverAccessToken(privateKey, encReceiverAccessToken);
		} catch (IOException e) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.RECEIVER_ACCESS_TOKEN_NOT_PRESENT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.EXCEPTION_RECEIVER_ACCESS_TOKEN_NOT_PRESENT + ExceptionUtils.getStackTrace(e));
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return null;
		}
		if (null == receiverAccessToken) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.RECEIVER_ACCESS_TOKEN_NOT_PRESENT);
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return null;
		}
		String senderTokenHash = null;
		senderTokenHash = edmsEncryption.generateSenderTokenHash(receiverAccessToken);
		if (null == senderTokenHash) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.SENDER_ACCESS_TOKEN_NOT_PRESENT);
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return null;
		}
		boolean hashMatched = false;
		hashMatched = edmsEncryption.verifyReceiverTokenHash(edmsServerPublicKey, signedReceiverTokenHash,
				senderTokenHash);
		if (hashMatched) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, EdmsUploadConstants.HASH_MATCHED);
			String signedSenderTokenHash = null;
			try {
				FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
						EdmsUploadConstants.SIGNED_SENDER_TOKEN_HASH_PRESENT);
				signedSenderTokenHash = edmsEncryption.signSenderTokenHash(privateKey, senderTokenHash);
				if (null == signedSenderTokenHash) {
					FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
							EdmsUploadConstants.SIGNED_SENDER_TOKEN_HASH_NOT_PRESENT);
					FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
					return null;
				}
			} catch (NoSuchAlgorithmException | SignatureException e) {
				FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
						EdmsUploadConstants.SIGNED_SENDER_TOKEN_HASH_NOT_PRESENT);
				FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
						EdmsUploadConstants.EXCEPTION_SIGNED_SENDER_TOKEN_HASH_NOT_PRESENT
								+ ExceptionUtils.getStackTrace(e));
				FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
				return null;
			}
			String signedSenderTokenHashWithID = signedSenderTokenHash + EdmsUploadConstants.COMMA + uniqueVKYCServerID;
			signedSenderTokenHashWithID = signedSenderTokenHashWithID.replace(EdmsUploadConstants.BACK_SLASH_N,
					EdmsUploadConstants.EMPTY);
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			try {
				FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
						EdmsUploadConstants.REUSE_TOKEN_PRESENT);
				FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
				return reuseToken(signedSenderTokenHashWithID, request, gson, edmsURL, edmsServerPublicKey, privateKey);
			} catch (IllegalBlockSizeException | NoSuchAlgorithmException | IOException e) {
				FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
						EdmsUploadConstants.REUSE_TOKEN_NOT_PRESENT);
				FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
						EdmsUploadConstants.EXCEPTION_REUSE_TOKEN_NOT_PRESENT + ExceptionUtils.getStackTrace(e));
				FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
				return null;
			}
		} else {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.HASH_MATCHED_FALSE);
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return null;
		}
	}

	/**
	 * Method Name: uniqueServerIdGeneration Description: Generate Unique Source
	 * Server Id
	 * 
	 * @param channelId
	 * @param uniqueVKYCServerID
	 * @return String
	 */
	public String uniqueServerIdGeneration(String channelId, String uniqueVKYCServerID) {
		String thisMethod = EdmsUploadConstants.UNIQUE_SERVER_ID_GENERATION;
		FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_STARTED);
		Gson gsonOne = new GsonBuilder().serializeNulls().disableHtmlEscaping().setPrettyPrinting().create();
		TempReqBeanNtb tempReq = new TempReqBeanNtb();
		TempReqBean tempReqBean = new TempReqBean();
		String uniqueSourceServerID;
		if (Arrays
				.asList(CmnParamsConst.getMap().get(Constants.NTB_APPWEB_SA_EKYC_KEY),
						CmnParamsConst.getMap().get(Constants.NTB_APPWEB_CA_EKYC_KEY),
						CmnParamsConst.getMap().get(Constants.ETB_APPWEB_PF_KEY),
						CmnParamsConst.getMap().get(EdmsUploadConstants.REKYC_SECOND_E_KEY),
						CmnParamsConst.getMap().get(EdmsUploadConstants.REKYC_SECOND_D_KEY),
						CmnParamsConst.getMap().get(EdmsUploadConstants.REKYC_FOURTH_E_KEY),
						CmnParamsConst.getMap().get(EdmsUploadConstants.REKYC_SIXTH_D_KEY),
						CmnParamsConst.getMap().get(EdmsUploadConstants.REKYC_EIGHTH_E_KEY),
						CmnParamsConst.getMap().get(EdmsUploadConstants.REKYC_NINTH_E_KEY),
						CmnParamsConst.getMap().get(EdmsUploadConstants.REKYC_TWELVE_E_KEY), "Y2EDNRI")
				.contains(channelId)) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.CALL_API_FOR_PATH2);
			if (channelId.contains(EdmsUploadConstants.REKYC_VID_CHANNLE_ID)) {
				FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
						EdmsUploadConstants.REKYC_TEMP_REQ);
				channelId = EdmsUploadConstants.REKYC_VID_CHANNLE_ID;
			}
			tempReq.setUniqueVKYCServerID(uniqueVKYCServerID);
			if (channelId.equals("Y2EDNRI")||channelId.equals("Y2NDSSA")) {
				tempReq.setChannelID("Y2NDSSA");
				uniqueSourceServerID = gsonOne.toJson(tempReq);
			} else {
				tempReq.setChannelID(channelId);
				uniqueSourceServerID = gsonOne.toJson(tempReq);
			}
		} else {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.CALL_API_FOR_PATH_FOUR);
			tempReqBean.setUniqueSourceServerID(uniqueVKYCServerID);
			tempReqBean.setChannelID(channelId);
			uniqueSourceServerID = gsonOne.toJson(tempReqBean);
		}
		FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
		return uniqueSourceServerID;
	}

	/**
	 * Method Name : reuseToken Description : This method generate reuseToken
	 * EDMSResponse
	 * 
	 * @param signedSenderTokenHashWithID
	 * @param request
	 * @param gsonOne
	 * @param edmsURL
	 * @param edmsServerPublicKey
	 * @param privateKey
	 * @return EDMSResponse
	 * @throws IllegalBlockSizeException
	 * @throws IOException
	 * @throws NoSuchAlgorithmException
	 */
	public EDMSResponse reuseToken(String signedSenderTokenHashWithID, Object request, Gson gsonOne, String edmsURL,
			PublicKey edmsServerPublicKey, PrivateKey privateKey)
			throws IllegalBlockSizeException, IOException, NoSuchAlgorithmException {
		String thisMethod = EdmsUploadConstants.REUSE_TOKEN;
		FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_STARTED);
		EDMSEncryption edmsEncryption = new EDMSEncryption();
		Gson gson = null;
		if (gsonOne != null) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.GSON_BUILDER_PRESENT);
			gson = gsonOne;
		} else {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.GSON_BUILDER_NOT_PRESENT);
			gson = new GsonBuilder().create();
		}
		HttpHeaders headers = new HttpHeaders();
		RestTemplate restTemplate = new RestTemplate(getClientHttpRequestFactory(15000, 45000));
		String decryptedResponse = null;
		String finalJSONReq = null;
		finalJSONReq = gson.toJson(request);
		if (null == finalJSONReq) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.FINAL_JSON_REQ_IS_NULL);
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return null;
		}
		SecretKey aesKey = null;
		aesKey = edmsEncryption.generateAESkey();
		if (null == aesKey) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.AES_KEY_NOT_PRSNT);
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return null;
		}
		String encryptedRequest = null;
		encryptedRequest = edmsEncryption.encryptRawJSON(aesKey, edmsServerPublicKey, finalJSONReq);
		FLogger.info(finalJSONReq, encryptedRequest);

		headers.setContentType(MediaType.APPLICATION_JSON);
		headers.add(Constants.SIGNED_SENDER_TOKEN, signedSenderTokenHashWithID);
		HttpEntity<String> finalRequestToEDMS = null;

		finalRequestToEDMS = new HttpEntity<>(encryptedRequest, headers);
		try {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.SSL_UTIL_TURN_OFF_SSL_CHECKING);
			SSLUtil.turnOffSSLChecking();
		} catch (KeyManagementException | NoSuchAlgorithmException e) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.SSL_UTIL_TURN_OFF_SSL_CHECKING_NOT_PRESENT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.SSL_UTIL_TURN_OFF_SSL_CHECKING_NOT_PRESENT + ExceptionUtils.getStackTrace(e));
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return null;
		}
		ResponseEntity<String> finalResponseString = null;
		try {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.FINAL_RESPONSE_STRING_CHECKING);
			SSLUtil.turnOffSSLChecking();
			finalResponseString = restTemplate.postForEntity(edmsURL, finalRequestToEDMS, String.class);
		} catch (RestClientException | KeyManagementException | IllegalArgumentException e) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.FINAL_RESPONSE_STRING_NOT_PRESENT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.FINAL_RESPONSE_STRING_NOT_PRESENT + ExceptionUtils.getStackTrace(e));
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return null;
		}
		if (finalResponseString.getStatusCode() != HttpStatusCode.valueOf(EdmsUploadConstants.TWO_HUNDRED)) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.UNABLE_TO_CONNECT_TO_THE_SERVER);
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return null;
		}

		String encFinalResponseFromEDMS = finalResponseString.getBody();
		if (null == privateKey) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.PRIVATE_KEY_NOT_PRESENT);
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return null;
		}
		decryptedResponse = edmsEncryption.decryptResponse(encFinalResponseFromEDMS, privateKey);
		if (null == decryptedResponse) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.DECRYPTED_RESPONSE_NULL);
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return null;
		}
		EDMSResponse finalResponse = gson.fromJson(decryptedResponse, EDMSResponse.class);
		if (finalResponse.getResponseCode() != null && !finalResponse.getResponseCode().isEmpty()) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.FINAL_RESPONSE_PRESENT);
			EDMSResponse dl = finalResponse;
			if (finalResponse.getResponseCode().contains(EdmsUploadConstants.ZERO_ZERO)) {
				FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
						EdmsUploadConstants.RESPONSE_CODE_CONTAINS_ZERO);
			}
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return dl;
		} else {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EdmsUploadConstants.RESPONSE_CODE_NULL);
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return null;
		}
	}

	/**
	 * Method Name : getClientHttpRequestFactory Description :
	 * SimpleClientHttpRequestFactory getClientHttpRequestFactory
	 * 
	 * @param connectTimeout
	 * @param readTimeout
	 * @return SimpleClientHttpRequestFactory
	 */
	public static SimpleClientHttpRequestFactory getClientHttpRequestFactory(int connectTimeout, int readTimeout) {
		String thisMethod = EdmsUploadConstants.GET_CLIENT_HTTP_REQUEST_FACTORY;
		FLogger.info(Constants.TIER_NAME, EdmsUploadConstants.THIS_CLASS, thisMethod, Constants.METHOD_STARTED);
		SimpleClientHttpRequestFactory sc = new SimpleClientHttpRequestFactory();
		sc.setConnectTimeout(connectTimeout);
		sc.setReadTimeout(readTimeout);
		FLogger.info(Constants.TIER_NAME, EdmsUploadConstants.THIS_CLASS, thisMethod, Constants.METHOD_END);
		return sc;
	}




