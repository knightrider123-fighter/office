			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.UNABLE_TO_UPLOAD_USER + ExceptionUtils.getStackTrace(e));
			throw new AESKeyGenerationException(Constants.RUNTIME_D);
		}
		aesKeyGenerator.init(256);
		SecretKey aesKey = aesKeyGenerator.generateKey();
		aesKey.hashCode();
		FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
		return aesKey;
	}

	/**
	 * Method Name : encryptRawJSON Method to encrypt the data using a hybrid
	 * crypto-system which uses GCM to encrypt the data and OAEP to encrypt the AES
	 * key. The key size of the AES encryption will be 256 bit. All the default
	 * parameter choices are used for OAEP and GCM using SHA-256 and MFG1 Padding.
	 * 
	 * @param aesKey
	 * @param edmsServerPublicKey
	 * @param rawJSON
	 * @return Base64 encoded String.
	 * @throws IllegalBlockSizeException
	 * @throws IOException
	 */
	public String encryptRawJSON(SecretKey aesKey, PublicKey edmsServerPublicKey, String rawJSON)
			throws IllegalBlockSizeException, IOException {
		String thisMethod = EncryptionConstants.ENCRYPTION_RAW_JSON;
		FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_STARTED);
		Cipher oaep = null;
		OAEPParameterSpec oaepParameterSpec = null;
		try {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.INTO_TRY_ENCRYPTION_RAW_JSON);
			oaep = Cipher.getInstance(Constants.RSA);
			oaepParameterSpec = new OAEPParameterSpec(Constants.SHA, Constants.MGF1, MGF1ParameterSpec.SHA256,
					PSpecified.DEFAULT);
		} catch (NoSuchAlgorithmException | NoSuchPaddingException e) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, EncryptionConstants.CIPHER_RSA);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.OEAP_PARAMETER_SPEC_NULL + ExceptionUtils.getStackTrace(e));
			throw new AESKeyGenerationException(Constants.SHA);
		}
		try {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.INTO_TRY_ENCRYPTION_RAW_JSON);

			oaep.init(Cipher.WRAP_MODE, edmsServerPublicKey, oaepParameterSpec);
		} catch (InvalidAlgorithmParameterException | InvalidKeyException e1) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.OEAP_NOT_INITIALIZE);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.OEAP_NOT_INITIALIZE + ExceptionUtils.getStackTrace(e1));
		}
		ByteBuffer rawJSONBuffer = null;
		rawJSONBuffer = ByteBuffer.wrap(rawJSON.getBytes(StandardCharsets.UTF_8));
		byte[] wrappedKey = null;
		try {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.CONST_FLOGGER);
			wrappedKey = oaep.wrap(aesKey);
		} catch (IllegalBlockSizeException | InvalidKeyException e) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.WRAP_KEY_NOT_PRESENT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.WRAP_KEY_NOT_PRESENT + ExceptionUtils.getStackTrace(e));
			ExceptionUtils.getStackTrace(e);
			throw new IllegalBlockSizeException(Constants.EXCEPTION);
		}
		Cipher aesGCM = null;
		try {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.ASEGCM_PRESENT);
			aesGCM = Cipher.getInstance(Constants.AES_GCM);
			GCMParameterSpec staticParameterSpec = new GCMParameterSpec(128, new byte[12]);
			aesGCM.init(1, aesKey, staticParameterSpec);
		} catch (NoSuchAlgorithmException | NoSuchPaddingException | InvalidAlgorithmParameterException
				| InvalidKeyException e) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.GCM_PARAM_SPEC_NOT_PRESENT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.GCM_PARAM_SPEC_NOT_PRESENT + ExceptionUtils.getStackTrace(e));
			throw new IOException(Constants.EXCEPTION, e);
		}
		ByteBuffer cipherTextBuffer = null;
		cipherTextBuffer = ByteBuffer
				.allocate(Short.BYTES + oaep.getOutputSize(EncryptionConstants.OEAP_BYTE_SIZE / Byte.SIZE)
						+ aesGCM.getOutputSize(rawJSON.getBytes(StandardCharsets.UTF_8).length));
		if (wrappedKey == null) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.WRAPPED_KEY_NOT_PRESENT);
			throw new NullPointerException(Constants.WREPPEDKEY_C_B_N);
		}
		cipherTextBuffer.putShort((short) wrappedKey.length);
		cipherTextBuffer.put(wrappedKey);
		try {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.ASEGCM_DOFINAL_PRESENT);
			aesGCM.doFinal(rawJSONBuffer, cipherTextBuffer);
		} catch (Exception e) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.ASEGCM_DOFINAL_NOT_PRESENT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.ASEGCM_DOFINAL_NOT_PRESENT + ExceptionUtils.getStackTrace(e));
			throw new IOException(Constants.CRYPTOGRAPHI_E_AES, e);
		}
		FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
		return Base64.encodeBase64String(cipherTextBuffer.array());
	}

	/**
	 * Method Name: decReceiverAccessToken Method to decrypt base64 encoded receiver
	 * access token sent by EDMS in temporary response using RSA with SHA-256
	 * algorithms.
	 * 
	 * @param privateKey
	 * @param encReceiverAccessToken
	 * @return String
	 * @throws IOException
	 */
	public String decReceiverAccessToken(PrivateKey privateKey, String encReceiverAccessToken) throws IOException {
		String thisMethod = EncryptionConstants.DEC_RECIVER_ACCESS_TOKEN;
		FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_STARTED);
		Cipher oaep = null;
		OAEPParameterSpec oaepParameterSpec = null;
		byte[] decReceiverAccessTokenBytes = null;
		try {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, EncryptionConstants.OEAP_PRESENT);
			oaep = Cipher.getInstance(Constants.RSA);
			oaepParameterSpec = new OAEPParameterSpec(Constants.SHA, Constants.MGF1, MGF1ParameterSpec.SHA256,
					PSpecified.DEFAULT);
			oaep.init(Cipher.DECRYPT_MODE, privateKey, oaepParameterSpec);
			byte[] tokenCipherTextBytes = null;
			tokenCipherTextBytes = Base64.decodeBase64(encReceiverAccessToken.getBytes(StandardCharsets.UTF_8));
			decReceiverAccessTokenBytes = oaep.doFinal(tokenCipherTextBytes);
		} catch (NoSuchAlgorithmException | NoSuchPaddingException | InvalidAlgorithmParameterException
				| InvalidKeyException | IllegalBlockSizeException | BadPaddingException e1) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.OEAP_INIT_NOT_PRESENT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.OEAP_INIT_NOT_PRESENT + ExceptionUtils.getStackTrace(e1));
			throw new IOException(Constants.EXCEPTION, e1);
		}
		if (decReceiverAccessTokenBytes != null) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.DECR_REC_ACC_TKN_PRSNT);
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return new String(decReceiverAccessTokenBytes, StandardCharsets.UTF_8);
		} else {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.DECR_REC_ACC_TKN_NOT_PRSNT);
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.DECR_REC_ACC_TKN_NOT_PRSNT);
			throw new IOException(EncryptionConstants.UNABLE_DECRYPT);
		}
	}

	/**
	 * Method Name: generateSenderTokenHash Method to generate sender token hash for
	 * temporary request sent to EDMS.
	 * 
	 * @param receiverAccessToken
	 * @return String of generateSenderTokenHash
	 */
	public String generateSenderTokenHash(String receiverAccessToken) {
		String thisMethod = EncryptionConstants.GEN_SENDER_TOKEN_HASH;
		FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_STARTED);
		MessageDigest messageDigest = null;
		byte[] encodedSenderTokenHash = null;
		String senderTokenHash = null;
		try {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.MSG_DIGEST_PRSNT);
			messageDigest = MessageDigest.getInstance(Constants.SHA);
		} catch (NoSuchAlgorithmException e) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.MSG_DIGEST_NOT_PRSNT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.MSG_DIGEST_NOT_PRSNT + ExceptionUtils.getStackTrace(e));
		}
		if (messageDigest != null) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.MSG_DIGEST_PRSNT);
			encodedSenderTokenHash = messageDigest.digest(receiverAccessToken.getBytes(StandardCharsets.UTF_8));
			if (encodedSenderTokenHash != null) {
				FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
						EncryptionConstants.ENC_SNDR_TKN_HASH);
				senderTokenHash = bytesToHex(encodedSenderTokenHash);
			} else {
				FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
						EncryptionConstants.ENC_SNDR_TKN_HASH_NOT_PRSNT);
			}
		} else {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.MSG_DIGEST_NOT_PRSNT);
		}
		FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
		return senderTokenHash;
	}

	/**
	 * Method Name : bytesToHex Method to generate String value from byte[].
	 * 
	 * @param bytes
	 * @return String converted value.
	 */
	private String bytesToHex(byte[] bytes) {
		String thisMethod = EncryptionConstants.BYTE_HEX;
		FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_STARTED);
		StringBuilder hexString = new StringBuilder(EncryptionConstants.BYTE_HEX_MULT * bytes.length);
		for (byte b : bytes) {
			String hex = Integer.toHexString(0xff & b);
			if (hex.length() == EncryptionConstants.INTONE) {
				FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, EncryptionConstants.HEX_PRSNT);
				hexString.append('0');
			}
			hexString.append(hex);
		}
		FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
		return hexString.toString();
	}

	/**
	 * Method Name : verifyReceiverTokenHash Method to verify signed receiver token
	 * hash sent by EDMS using SHA256withRSA Signature.
	 * 
	 * @param edmsServerPublicKey
	 * @param signedReceiverTokenHash
	 * @param senderTokenHash
	 * @return boolean value to confirm the verification
	 */
	public boolean verifyReceiverTokenHash(PublicKey edmsServerPublicKey, String signedReceiverTokenHash,
			String senderTokenHash) {
		String thisMethod = EncryptionConstants.VERIFY_RECIVER_TOKEN;
		FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_STARTED);
		boolean hashMatched = false;

		Signature publicSignature = null;
		try {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.PUBLIC_SIGN_PRSNT);
			publicSignature = Signature.getInstance(Constants.PUBLIC_SIGNATURE);
		} catch (NoSuchAlgorithmException e) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.PUBLIC_SIGN_NOT_PRSNT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.PUBLIC_SIGN_NOT_PRSNT + ExceptionUtils.getStackTrace(e));
		}
		if (publicSignature != null) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.VALID_KEY_EXPN);
			try {
				FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
						EncryptionConstants.PUBLIC_SIGN_VERYFY_PRSNT);
				publicSignature.initVerify(edmsServerPublicKey);
			} catch (InvalidKeyException e) {
				FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
						EncryptionConstants.PUBLIC_SIGN_VERYFY_NOT_PRSNT);
				FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
						EncryptionConstants.PUBLIC_SIGN_VERYFY_NOT_PRSNT + ExceptionUtils.getStackTrace(e));
			}
		} else {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, EncryptionConstants.INVLD_KEY_EXP);
		}
		if (publicSignature != null) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.PUBLIC_SIGN_PRSNT);
			try {
				FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
						EncryptionConstants.PUBLIC_SIGN_PRSNT);
				publicSignature.update(senderTokenHash.getBytes(StandardCharsets.UTF_8));
			} catch (SignatureException e) {
				FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
						EncryptionConstants.PUBLIC_SIGN_NOT_PRSNT);
				FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
						EncryptionConstants.PUBLIC_SIGN_NOT_PRSNT + ExceptionUtils.getStackTrace(e));

			}
		} else {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.PUBLIC_SIGN_NOT_PRSNT);
		}
		byte[] signatureBytes = Base64.decodeBase64(signedReceiverTokenHash);
		if (publicSignature != null) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.PUBLIC_SIGN_PRSNT);
			try {
				FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
						EncryptionConstants.PUBLIC_SIGN_HASH_PRSNT);
				hashMatched = publicSignature.verify(signatureBytes);
			} catch (SignatureException e) {
				FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
						EncryptionConstants.PUBLIC_SIGN_HASH_NOT_PRSNT);
				FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
						EncryptionConstants.PUBLIC_SIGN_HASH_NOT_PRSNT + ExceptionUtils.getStackTrace(e));
			}
		} else {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.PUBLIC_SIGN_NOT_PRSNT);
		}
		FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
		return hashMatched;
	}

	/**
	 * Method Name : signSenderTokenHash Method to generate Base64 encoded sender
	 * token hash sent to EDMS in f al request.
	 * 
	 * @param privateKey
	 * @param senderTokenHash
	 * @return String
	 * @throws NoSuchAlgorithmException
	 * @throws SignatureException
	 */
	public String signSenderTokenHash(PrivateKey privateKey, String senderTokenHash)
			throws NoSuchAlgorithmException, SignatureException {
		String thisMethod = EncryptionConstants.SIGN_SNDR_TOKEN_HASH;
		FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_STARTED);
		try {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.PRIVATE_SIGN_PRSNT);
			Signature privateSignature = Signature.getInstance(Constants.PUBLIC_SIGNATURE);
			privateSignature.initSign(privateKey);
			privateSignature.update(senderTokenHash.getBytes(StandardCharsets.UTF_8));
			byte[] signature = privateSignature.sign();
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
			return Base64.encodeBase64String(signature);
		} catch (InvalidKeyException e) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.PRIVATE_SIGN_NOT_PRSNT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.PRIVATE_SIGN_NOT_PRSNT + ExceptionUtils.getStackTrace(e));
			return null;
		}
	}

	/**
	 * Method Name : decryptResponse Method to decrypt the cipher text using a
	 * hybrid crypto-system which uses GCM to encrypt the rawJSON and OAEP to
	 * encrypt the AES key. All the default parameter choices are used for OAEP and
	 * GCM using SHA-256 and MFG1 Padding.
	 * 
	 * @param encryptedResponse
	 * @param privateKey
	 * @return String
	 * @throws IOException
	 */
	public String decryptResponse(String encryptedResponse, PrivateKey privateKey) throws IOException {
		String thisMethod = EncryptionConstants.DCRYPT_RESP;
		FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_STARTED);
		Cipher oaep = null;
		OAEPParameterSpec oaepParameterSpec = null;
		try {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, EncryptionConstants.OEAP_PRESENT);
			oaep = Cipher.getInstance(Constants.RSA);
			oaepParameterSpec = new OAEPParameterSpec(Constants.SHA, "MGF1", MGF1ParameterSpec.SHA256,
					PSpecified.DEFAULT);
		} catch (NoSuchAlgorithmException | NoSuchPaddingException e) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.OEAP_NOT_PRSNT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.OEAP_NOT_PRSNT + ExceptionUtils.getStackTrace(e));
			throw new IOException(Constants.RUNTIME_D, e);
		}
		try {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.OEAP_INIT_PRSNT);
			oaep.init(Cipher.UNWRAP_MODE, privateKey, oaepParameterSpec);
		} catch (InvalidAlgorithmParameterException | InvalidKeyException e1) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.OEAP_INIT_NOT_PRESENT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.OEAP_INIT_NOT_PRESENT + ExceptionUtils.getStackTrace(e1));
		}
		byte[] encryptedBytes = null;
		if (encryptedResponse == null) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.ENCRYPT_RSP_NULL);
			return null;
		}
		encryptedBytes = Base64.decodeBase64(encryptedResponse.getBytes(StandardCharsets.UTF_8));
		ByteBuffer ciphertextBuffer = ByteBuffer.wrap(encryptedBytes);
		if (ciphertextBuffer.remaining() < 2) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.CIPHER_TXT_BUFFER_PRSNT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.CIPHER_TXT_BUFFER_NOT_PRSNT);
			throw new IllegalArgumentException(Constants.INVALIDCIPHERTEXT);
		}
		int wrappedKeySize = ciphertextBuffer.getShort() & 0xFFFF;
		if (ciphertextBuffer.remaining() < wrappedKeySize + 128 / Byte.SIZE) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.CIPHER_TXT_BUFFER_RMG_PRSNT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.CIPHER_TXT_BUFFER_RMG_NOT_PRSNT);
			throw new IllegalArgumentException(Constants.INVALIDCIPHERTEXT);
		}
		byte[] wrappedKey = new byte[wrappedKeySize];
		ciphertextBuffer.get(wrappedKey);
		SecretKey aesKey = null;
		try {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, EncryptionConstants.ASE_KEY_PRSNT);
			aesKey = (SecretKey) oaep.unwrap(wrappedKey, "AES", Cipher.SECRET_KEY);
		} catch (NoSuchAlgorithmException | InvalidKeyException e) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.ASE_KEY_NOT_PRSNT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.ASE_KEY_NOT_PRSNT + ExceptionUtils.getStackTrace(e));
			throw new IOException(Constants.RUNTIME_D, e);
		}
		Cipher aesGCM = null;
		try {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.ASEGCM_PRESENT);
			aesGCM = Cipher.getInstance(Constants.AES_GCM);

			GCMParameterSpec staticParameterSpec = new GCMParameterSpec(128, new byte[12]);

			aesGCM.init(2, aesKey, staticParameterSpec);
		} catch (NoSuchAlgorithmException | NoSuchPaddingException | InvalidAlgorithmParameterException
				| InvalidKeyException e) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.ASEGCM_NOT_PRESENT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.ASEGCM_NOT_PRESENT + ExceptionUtils.getStackTrace(e));
			throw new IOException(Constants.RUNTIME_D, e);
		}
		ByteBuffer rawJSONBuffer = ByteBuffer.allocate(aesGCM.getOutputSize(ciphertextBuffer.remaining()));
		try {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, EncryptionConstants.ASEGCM_DOFINAL_PRESENT);
			aesGCM.doFinal(ciphertextBuffer, rawJSONBuffer);
		} catch (ShortBufferException e) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.SHORT_BUFFER_NOT_PRSNT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.SHORT_BUFFER_NOT_PRSNT + ExceptionUtils.getStackTrace(e));
			throw new IOException(Constants.SHORT_BUFFER);
		} catch (IllegalBlockSizeException e) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.ILLEGAL_BLOCK_NOT_PRSNT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.ILLEGAL_BLOCK_NOT_PRSNT + ExceptionUtils.getStackTrace(e));
			throw new IOException(Constants.ILLEGALEX);
		} catch (BadPaddingException e) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.BAD_PADDING_NOT_PRSNT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.BAD_PADDING_NOT_PRSNT + ExceptionUtils.getStackTrace(e));
			throw new IOException(Constants.BADPADDING);
		} catch (Exception e) {
			FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.EXP_ASEGCM_NOT_PRESENT);
			FLogger.error(Constants.TIER_NAME, this.getClass().getName(), thisMethod,
					EncryptionConstants.EXP_ASEGCM_NOT_PRESENT + ExceptionUtils.getStackTrace(e));
			throw new IOException(Constants.INVALIDCIPHERTEXT);
		}
		FLogger.info(Constants.TIER_NAME, this.getClass().getName(), thisMethod, Constants.METHOD_END);
		return new String(rawJSONBuffer.array(), StandardCharsets.UTF_8);
	}
}
package com.sbi.yono.document.savingsaccount.edms.encryption;

public class EncryptionConstants {

	public static final int LENGTH = 16;
