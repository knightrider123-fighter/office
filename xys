    public PdfCreation(DocumentMasterRepo documentMasterRepo) {
        this.documentMasterRepo = documentMasterRepo;
    }


    public String returnValue(String value) {

        if (value == null || value.equals(Constants.NULL_VALUE) || value.isEmpty()
                || value.trim().equals(CommonEkycConstant.BLANK) || value.equals(CommonEkycConstant.ZERO)) {
            return "NA";
        } else {
            return value;
        }
    }

    public String printer(String leadId) throws ServiceBusinessException, ServiceException {
//        String path = "D:\\Jasper\\task1pdfjasper.jrxml";
        File path = new File("D:/Jasper/task1pdfjasper.jrxml");
//        Optional<DcmntMstr> dcmntMstrInfo = documentMasterRepo.findById(leadId);
        pdfParameterFill();
        List<String> list = new ArrayList<>();
        list.add(Constants.PDF);
        JRBeanCollectionDataSource dataSource = new JRBeanCollectionDataSource(list);
        JasperReport report;
        try {
            report = JasperCompileManager.compileReport(path.getAbsolutePath());

            JasperPrint print = JasperFillManager.fillReport(report, parameters, dataSource);
            JRPdfExporter exporter = new JRPdfExporter();
            ByteArrayOutputStream pdfOutputStream = new ByteArrayOutputStream();
            exporter.setExporterInput(new SimpleExporterInput(print));
            exporter.setExporterOutput(new SimpleOutputStreamExporterOutput(pdfOutputStream));
            SimplePdfExporterConfiguration configuration = new SimplePdfExporterConfiguration();
            configuration.setEncrypted(true);
            configuration.set128BitKey(false);
            exporter.setConfiguration(configuration);
            exporter.exportReport();
            byte[] pdfByte = pdfOutputStream.toByteArray();
            String encodeToString = Base64.getEncoder().encodeToString(pdfByte);
            System.out.println(encodeToString);
            return encodeToString;
        } catch (JRException e) {
            System.out.println(e.getMessage());
            return null;
        }
    }

